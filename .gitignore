# ─────────────────────────────────────────────────────────────
# Vibe Coding Mastery — Public Repo .gitignore
# ─────────────────────────────────────────────────────────────
# Private course materials are tracked in the SEPARATE private repo:
#   github.com/AQaddora/vibe-coding-mastery-private
#
# This .gitignore enforces that no private content can leak from
# this folder, in addition to the structural separation.
# ─────────────────────────────────────────────────────────────

# Private session content (paid course material) — DO NOT TRACK
sessions/*/private/**
!sessions/*/private/.gitkeep
!sessions/*/private/README.md

# Local doctrine (user-specific, never published)
ai-doctrine.md
**/ai-doctrine.md
!skills/doctrine-keeper/scripts/bootstrap.py

# AI tool config files generated by sync_to_agents.sh in user projects
# (these are produced by users running the installer, not by this repo)
CLAUDE.md.user
AGENTS.md.user

# LibreOffice cruft (left over when generating slides.pdf)
.~lock.*#
*.tmp
~$*

# Slides PDF — kept tracked for distribution, but ignore intermediate regens
# (the canonical PDF is generated by tools/build-slides — re-run if pptx changes)

# Node / JS tooling
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
*.log
logs/
